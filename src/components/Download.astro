---
import Icon from './Icon.astro'
import AnchorHeading from './AnchorHeading.astro'
import { repo } from '../data/site.js'
---

<section class="download" id="download">
  <div class="wrap">
    <div class="section-head">
      <AnchorHeading id="download">Download Pelton</AnchorHeading>
      <p>
        Every release ships unsigned installers for macOS, Windows and Fedora. First launch needs one
        extra step on macOS and Windows, since the builds are not code-signed.
      </p>
    </div>

    <div class="dl-card">
      <div class="dl-primary">
        <h3 id="dl-title">Get the latest release</h3>
        <p id="dl-sub">Detecting your platform and the newest build.</p>
      </div>
      <div class="dl-buttons">
        <a class="btn accent" id="dl-primary" href={repo.releasesLatest} target="_blank" rel="noreferrer noopener">
          <span class="dl-icon" data-icon="download"><Icon name="download" size={18} /></span>
          <span class="dl-icon" data-icon="mac" hidden><Icon name="apple" size={18} /></span>
          <span class="dl-icon" data-icon="win" hidden><Icon name="brand-windows" size={18} /></span>
          <span class="dl-icon" data-icon="fedora" hidden><Icon name="brand-redhat" size={18} /></span>
          <span id="dl-primary-label">Latest release</span>
        </a>
        <a class="btn ghost" href={repo.releases} target="_blank" rel="noreferrer noopener">
          <Icon name="external-link" size={17} />
          <span>All builds and releases</span>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const API = 'https://api.github.com/repos/TRC-Loop/Pelton/releases/latest'
  const FALLBACK = 'https://github.com/TRC-Loop/Pelton/releases/latest'

  const matchers: Record<string, RegExp> = {
    'mac-arm': /macos-applesilicon\.dmg$/i,
    'mac-intel': /macos-intel\.dmg$/i,
    win: /windows-amd64-installer\.exe$/i,
    fedora: /linux-fedora.*\.rpm$/i,
  }

  const labels: Record<string, string> = {
    'mac-arm': 'macOS (Apple Silicon)',
    'mac-intel': 'macOS (Intel)',
    win: 'Windows',
    fedora: 'Fedora Linux',
  }

  async function detectMac(): Promise<'mac-arm' | 'mac-intel'> {
    const uaData = (navigator as any).userAgentData
    if (uaData?.getHighEntropyValues) {
      try {
        const v = await uaData.getHighEntropyValues(['architecture'])
        if (v.architecture === 'arm') return 'mac-arm'
        if (v.architecture === 'x86') return 'mac-intel'
      } catch {}
    }
    return 'mac-arm'
  }

  async function detectPlatform(): Promise<string | null> {
    const ua = navigator.userAgent
    if (/Android/i.test(ua)) return null
    if (/Mac/i.test(ua) && !/iPhone|iPad|iPod/i.test(ua)) return await detectMac()
    if (/Win/i.test(ua)) return 'win'
    if (/Linux/i.test(ua)) return 'fedora'
    return null
  }

  function setText(id: string, text: string): void {
    const el = document.getElementById(id)
    if (el) el.textContent = text
  }

  async function run(): Promise<void> {
    const platform = await detectPlatform()

    let assets: { name: string; browser_download_url: string }[] = []
    let version = ''
    try {
      const res = await fetch(API, { headers: { Accept: 'application/vnd.github+json' } })
      if (res.ok) {
        const data = await res.json()
        assets = data.assets || []
        version = data.tag_name || data.name || ''
      }
    } catch {}

    const urlFor = (key: string): string | null => {
      const m = matchers[key]
      const asset = assets.find((a) => m.test(a.name))
      return asset ? asset.browser_download_url : null
    }

    if (version) {
      setText('dl-title', `Pelton ${version}`)
    }
    setText('dl-sub', version
      ? 'The newest build, straight from GitHub releases.'
      : 'Open the latest release on GitHub to pick your build.')

    const primary = document.getElementById('dl-primary') as HTMLAnchorElement | null
    if (platform) {
      const url = urlFor(platform)
      setText('dl-primary-label', `Download for ${labels[platform]}`)
      if (primary) primary.href = url || FALLBACK

      const iconKey = platform.startsWith('mac') ? 'mac' : platform === 'win' ? 'win' : 'fedora'
      for (const el of document.querySelectorAll<HTMLElement>('.dl-icon')) {
        el.hidden = el.dataset.icon !== iconKey
      }
    }
  }

  run()
</script>
