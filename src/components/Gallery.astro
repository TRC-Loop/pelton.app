---
import AnchorHeading from './AnchorHeading.astro'
---

<section id="gallery">
  <div class="wrap">
    <div class="section-head">
      <AnchorHeading id="gallery">A real, native desktop app</AnchorHeading>
      <p>Three resizable panes, hairline borders, a quiet interface that gets out of the way.</p>
    </div>
    <div class="gallery-frame">
      <img
        src="/img/screenshot.webp"
        alt="Pelton desktop email client showing the three-pane layout"
        width="2784"
        height="1928"
        loading="lazy"
      />
    </div>
  </div>
</section>
