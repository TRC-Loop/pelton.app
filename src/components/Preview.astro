---
import Icon from './Icon.astro'
import DemoClient from './DemoClient.astro'
import AnchorHeading from './AnchorHeading.astro'

const presets = ['#465AF2', '#5B6470', '#3A7D5D', '#9A5B3A', '#7A4FB5', '#B5476A', '#2E8C9E', '#C28A1E']
const densities = [
  { key: 'compact', label: 'Compact' },
  { key: 'medium', label: 'Medium' },
  { key: 'luxe', label: 'Luxe' },
]
---

<section class="preview-section" id="preview">
  <div class="wrap">
    <div class="section-head">
      <AnchorHeading id="preview">Pick one color. The whole client follows</AnchorHeading>
      <p>
        Pelton derives selections, links and highlights from a single accent you choose. This is the
        same picker as the app's settings, wired to the same preview.
      </p>
    </div>
    <div class="picker">
      <div class="picker-controls">
        <span class="accent-label">Accent color</span>
        <div class="swatches" id="swatches" role="group" aria-label="Accent presets">
          {presets.map((hex, i) => (
            <button
              type="button"
              class="swatch"
              data-hex={hex}
              aria-pressed={i === 0 ? 'true' : 'false'}
              aria-label={`Accent ${hex}`}
              style={`background:${hex}`}
            >
              <span class="swatch-check"><Icon name="check" size={14} stroke={2.4} /></span>
            </button>
          ))}
        </div>

        <span class="accent-label density-label">Density</span>
        <div class="density-toggle" id="density-toggle" role="group" aria-label="Density">
          {densities.map((d, i) => (
            <button type="button" class="density-btn" data-density={d.key} aria-pressed={i === 1 ? 'true' : 'false'}>
              {d.label}
            </button>
          ))}
        </div>
      </div>
      <DemoClient />
    </div>
  </div>
</section>

<script>
  const hexPattern = /^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/

  function normalizeHex(input: string): string {
    let hex = input.trim().toLowerCase()
    if (hex.length === 4) {
      hex = '#' + hex[1] + hex[1] + hex[2] + hex[2] + hex[3] + hex[3]
    }
    return hex
  }

  function relativeLuminance(hex: string): number {
    const r = parseInt(hex.slice(1, 3), 16)
    const g = parseInt(hex.slice(3, 5), 16)
    const b = parseInt(hex.slice(5, 7), 16)
    const channel = (c: number) => {
      const s = c / 255
      return s <= 0.03928 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4)
    }
    return 0.2126 * channel(r) + 0.7152 * channel(g) + 0.0722 * channel(b)
  }

  function contrastForeground(hex: string): string {
    const lum = relativeLuminance(hex)
    const white = 1.05 / (lum + 0.05)
    const black = (lum + 0.05) / 0.05
    return white >= black ? '#ffffff' : '#000000'
  }

  const root = document.documentElement
  const swatches = Array.from(document.querySelectorAll<HTMLButtonElement>('#swatches .swatch'))

  function apply(raw: string): void {
    if (!hexPattern.test(raw.trim())) return
    const hex = normalizeHex(raw)
    root.style.setProperty('--accent', hex)
    root.style.setProperty('--accent-fg', contrastForeground(hex))
    for (const s of swatches) {
      s.setAttribute('aria-pressed', s.dataset.hex?.toLowerCase() === hex ? 'true' : 'false')
    }
  }

  for (const s of swatches) {
    s.addEventListener('click', () => apply(s.dataset.hex || ''))
  }

  const densityBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('#density-toggle .density-btn'))
  const client = document.getElementById('demo-client')

  for (const b of densityBtns) {
    b.addEventListener('click', () => {
      const density = b.dataset.density || 'medium'
      client?.setAttribute('data-density', density)
      for (const other of densityBtns) {
        other.setAttribute('aria-pressed', other === b ? 'true' : 'false')
      }
    })
  }
</script>
